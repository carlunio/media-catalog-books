PROJECT_ROOT=.
DB_PATH=data/books.duckdb
COVERS_DIR=data/input
COVERS_OUTPUT_DIR=data/output/covers
OCR_OUTPUT_DIR=ocr_output

OPENAI_API_KEY=
OCR_PROVIDER=ollama
OCR_OPENAI_MODEL=gpt-4o-mini
OCR_OLLAMA_MODEL=glm-ocr
# Default del checkbox "Reducir imagen a 1800 px (solo glm-ocr)" en UI.
# true = marcado por defecto; false = desmarcado por defecto.
OCR_RESIZE_TO_1800_DEFAULT=true
OCR_ISBN_OLLAMA_MODEL=gpt-oss:20b
# Coma-separated; si un modelo falla (ej. GGML_ASSERT), OCR intenta los siguientes.
# Vacio para desactivar fallback.
OCR_OLLAMA_FALLBACK_MODELS=
# Sugerencias visuales en la UI (CSV). En gris si no están instalados en backend.
OCR_OLLAMA_MODEL_SUGGESTIONS=glm-ocr:latest,glm-ocr
# Usa sidecar OCR_OUTPUT_DIR/<book_id>.txt en vez de OCR real sobre imagen.
# Recomendado false para forzar OCR desde imagen.
OCR_USE_SIDECAR=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=
CATALOG_MODEL=gpt-4o-mini
CATALOG_OPENAI_MODEL=gpt-4o-mini
CATALOG_OLLAMA_MODEL=qwen2.5:14b
CATALOG_PROVIDER=ollama
# Sugerencias visuales en la UI (CSV). En gris si no están instalados en backend.
CATALOG_OLLAMA_MODEL_SUGGESTIONS=qwen2.5:14b,qwen3:14b,qwen2.5:7b,llama3.1:8b
CATALOG_ARBITER_ENABLED=false
CATALOG_ARBITER_PROVIDER=auto
CATALOG_ARBITER_MIN_CONFIDENCE=0.72

ISBNDB_API_KEY=
REQUEST_TIMEOUT_SECONDS=20
WORKFLOW_MAX_ATTEMPTS=2
GOOGLE_BOOKS_MIN_INTERVAL_SECONDS=60
OPENLIBRARY_MIN_INTERVAL_SECONDS=60

API_URL=http://127.0.0.1:8000
API_TIMEOUT_SECONDS=90
API_LONG_TIMEOUT_SECONDS=900
# UI theme CSS path. Puede ser nombre en src/frontend/assets/ o ruta absoluta.
# Ejemplos: theme.css | theme_legacy.css
FRONTEND_THEME_CSS=theme.css
